{
  "title": "BER Chronik 1989–2017",
  "year_min": 1989,
  "year_max": 2017,
  "taxonomy": [
    {
      "name": "Fluggastaufkommen und Standortdebatten",
      "description": "Dokumentiert Passagierzahlen in Millionen für die drei Berliner Flughäfen Tegel, Schönefeld und Tempelhof sowie konkurrierende Standortvorschläge (Sperenberg, Jüterbog). Analysiert Abfertigungskapazitäten, Ausbaupotenziale und politische Frontlinien zwischen CDU/Bund (pro Schönefeld) und SPD/Gewerkschaften (pro Sperenberg), einschließlich Volksentscheide zur Tempelhof-Erhaltung.",
      "keywords": [
        "millionen",
        "schönefeld",
        "tegel",
        "berliner",
        "flughäfen"
      ]
    },
    {
      "name": "Eröffnungstermine und Aufsichtsratskrise",
      "description": "Dokumentiert wiederholte Verschiebungen des BER-Eröffnungstermins durch Mehdorn und die TSP mit gescheiterten Prognosen (2011, 2012, 2014, 2017). Zentral sind Aufsichtsratssitzungen zu Entrauchungsanlagen, Teilbaugenehmigungen und McKinsey-Warnungen vor Eröffnungsverzögerungen, berichtet durch BerlZtg und Tsp.",
      "keywords": [
        "ber",
        "tsp",
        "mehdorn",
        "aufsichtsrat",
        "eröffnung"
      ]
    },
    {
      "name": "Planfeststellung, Flugrouten und Nachtflugklagen",
      "description": "Behandelt Planfeststellungsbeschlüsse, DFS-Flugrouten-Konzepte und Nachtflugverbote zwischen 22 Uhr und 6 Uhr vor Gericht. Dokumentiert Bürgerinitiativen gegen Lärmkorridore, Bundesverwaltungsgerichtsurteile und verfassungsrechtliche Anfechtungen der landesplanerischen Festlegungen durch Brandenburg.",
      "keywords": [
        "uhr",
        "tsp",
        "nachtflugverbot",
        "klagen",
        "vor"
      ]
    },
    {
      "name": "Technikchefs und Brandschutzdefizite",
      "description": "Fokussiert auf Technikchefs Horst Amann und Jörg Marks sowie deren Verantwortung für Mängel an Brandschutzanlagen, Entrauchungsanlagen und Sprinkleranlagen. Behandelt Siemens-Verträge zur Behebung technischer Defizite, Imtech-Bestechungsfälle und Aufsichtsratsentscheidungen zur Bestandsaufnahme von Baugenehmigungsverletzungen.",
      "keywords": [
        "technikchef",
        "siemens",
        "tsp",
        "amann",
        "horst"
      ]
    },
    {
      "name": "Flughafengesellschaft und Privatisierungsversuche",
      "description": "Dokumentiert die Gründung der Berlin Brandenburg Flughafen GmbH (BBF/BBI) und gescheiterte Privatisierungsversuche durch Konsortien wie Hochtief und IVG. Behandelt Generalplaner (PG BBI), Schlechtleistungen bei Sicherheitstechnik und Gebäudeautomation sowie kartellrechtliche Beschwerdeverfahren gegen mangelnde Ingenieurkompetenz.",
      "keywords": [
        "berlin",
        "brandenburg",
        "bbf",
        "flughafen",
        "bbi"
      ]
    },
    {
      "name": "Wahlen, Koalitionen und Flughafenpolitik",
      "description": "Erfasst Wahlen zum Berliner Abgeordnetenhaus und Brandenburger Landtag sowie Koalitionsbildungen unter SPD-Führung mit Wowereit und Stolpe. Dokumentiert Wechsel von Bundesverkehrsministern, erfolgreiche Volksbegehrens für Nachtflugverbote und die Ablehnung von Privatisierungen „um jeden Preis\" durch die Landeschefs.",
      "keywords": [
        "spd",
        "wahl",
        "unter",
        "koalition",
        "abgeordnetenhaus"
      ]
    },
    {
      "name": "Kostenexplosion und Finanzierungslücken",
      "description": "Analysiert die Gesamtkosten des BER in Milliarden Euro (von 3,5 auf 6,6 Milliarden) mit Kapitalspritzen, Darlehen und Schuldenübernahmen durch Bund, Berlin und Brandenburg. Behandelt Finanzierungslücken von 500 Millionen bis 1,17 Milliarden Euro, EU-Beihilfegenehmigungen und Rentabilitätskritik bei Ausbauvarianten.",
      "keywords": [
        "euro",
        "milliarden",
        "millionen",
        "tsp",
        "mark"
      ]
    }
  ],
