# ── SECRETS (nie committen, Railway: railway variables set) ───────────────────
ANTHROPIC_API_KEY=              # Pflicht wenn LLM_PROVIDER=anthropic
VOYAGE_API_KEY=                 # Pflicht wenn EMBEDDING_PROVIDER=voyage
DROPBOX_APP_KEY=                # Dropbox-App-Credentials
DROPBOX_APP_SECRET=
ADMIN_KEY=                      # optional, schützt Admin-Endpoints
INVITES_JSON=                   # JSON-String mit invite-Tokens (Railway-Erststart → /data/invites.json)

# ── KONFIGURATION (lokal vs Railway unterschiedlich) ──────────────────────────
LLM_PROVIDER=anthropic          # anthropic|ollama  (Railway: anthropic)
EMBEDDING_PROVIDER=local        # local|voyage       (Railway: voyage)
OLLAMA_BASE_URL=http://localhost:11434  # nur lokal relevant
DROPBOX_REDIRECT_URL=http://localhost:8001/api/obsidian/oauth/callback  # Railway: produktive URL

# ── LAUFZEIT-DATEN (Volume auf Railway, lokal ./data) ─────────────────────────
DATA_ROOT=./data                # Railway: /data  (persistentes Volume)
